# Copy to .env or run `python setup.py` to generate this interactively.
PROVIDER=openai
MODEL=gpt-4o
API_KEY=sk-your-key-here

# Local provider (only used when PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Isolated agent workspace (absolute path recommended)
WORKSPACE_DIR=./workspace

# Runtime safety
COMMAND_TIMEOUT=45
MAX_ITERATIONS=50
MAX_HEALING_ATTEMPTS=3

# Web server
HOST=127.0.0.1
PORT=8000
